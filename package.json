{
  "name": "grok-build-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop client for Grok Build (ACP over agent serve)",
  "author": {
    "name": "falser101",
    "email": "falser101@users.noreply.github.com"
  },
  "homepage": "https://github.com/falser101/grok-build-desktop",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:wayland": "GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx XMODIFIERS=@im=fcitx ELECTRON_OZONE_PLATFORM_HINT=wayland electron-vite dev",
    "dev:x11": "GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx XMODIFIERS=@im=fcitx ELECTRON_OZONE_PLATFORM_HINT=x11 GROK_DESKTOP_WAYLAND_IME=0 electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty || true",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:linux:deb": "npm run build && electron-builder --linux deb",
    "dist:linux:rpm": "npm run build && electron-builder --linux rpm",
    "dist:linux:appimage": "npm run build && electron-builder --linux AppImage",
    "dist:win:nsis": "npm run build && electron-builder --win nsis",
    "dist:win:portable": "npm run build && electron-builder --win portable",
    "dist:mac:dmg": "npm run build && electron-builder --mac dmg",
    "dist:mac:zip": "npm run build && electron-builder --mac zip"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.1.0",
    "node-gyp": "^13.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "allowScripts": {
    "electron": true,
    "esbuild": true,
    "@electron/rebuild": true,
    "node-pty": true,
    "lzma-native": true
  }
}
